%% Fiducia HTTP client (Erlang) — build + publish config.
%% Requires OTP 27+ (uses the stdlib `json` module). No third-party runtime deps.
{erl_opts, [debug_info]}.

{deps, []}.

%% Publish to Hex with rebar3_hex:  rebar3 hex publish --yes
{project_plugins, [rebar3_hex]}.

%% Hex package metadata. The package name is the application name
%% (`fiducia_client`); licenses and links are declared in
%% src/fiducia_client.app.src, which rebar3_hex reads at publish time.
{hex, [{name, <<"fiducia_client">>},
       {licenses, [<<"UNLICENSED">>]},
       {links, #{<<"GitHub">> => <<"https://github.com/fiducia-cloud/fiducia-clients">>,
                 <<"Source">> => <<"https://github.com/fiducia-cloud/fiducia-clients/tree/main/clients/erlang">>}}]}.
